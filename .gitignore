# ----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# App specific Flutter ignores
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/.pub-cache/
app/.pub/
app/build/
app/coverage/
app/doc/api/
app/*.symbols
app/*.map.json

# iOS specific
app/ios/Flutter/.last_build_id
app/ios/Pods/
app/ios/.last_build_id
app/ios/DerivedData/
app/ios/Runner/GeneratedPluginRegistrant.h
app/ios/Runner/GeneratedPluginRegistrant.m

# macOS specific
app/macos/Flutter/ephemeral/
app/macos/Pods/

# Android specific
app/android/local.properties
app/android/key.properties
app/android/app/debug/
app/android/app/profile/
app/android/app/release/
